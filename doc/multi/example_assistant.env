# Assistant — Gemini Flash on Telegram. Personal-bot style: reminders,
# trackers, image recognition. Peers with generalist and cron-worker.

# Runtime identity
PB_RUNTIME_ID=assistant
PB_AGENT_NAME=Assistant

# Container-local runtime state
PB_BASE_DIR=/home/pillbug

# Gemini Flash — cheap, fast, native vision
PB_GEMINI_API_KEY=your_gemini_token
PB_GEMINI_MODEL=gemini-3.1-flash-preview
PB_GEMINI_THINKING_LEVEL=low

# Redis (bundled service in this compose stack)
PB_REDIS_HOST=redis
PB_REDIS_PORT=6379
PB_REDIS_DB=5
PB_DOCKET_NAME=d_assistant

# Summarization
PB_SESSION_SUMMARIZATION="compress"
PB_SESSION_SUMMARIZATION_THRESHOLD=32768

# HTTP server
PB_MCP_HOST=0.0.0.0
PB_MCP_PORT=8000

PB_DASHBOARD_BEARER_TOKEN=dashboard_bearer_token_123

# Channels
PB_ENABLED_CHANNELS=a2a,telegram
PB_CHANNEL_PLUGIN_FACTORIES=a2a=pillbug_a2a.a2a_channel:create_channel,telegram=pillbug_telegram.telegram_channel:create_channel

# Telegram
PB_TELEGRAM_BOT_TOKEN=111222333:tg_bot_token
PB_TELEGRAM_ALLOWED_CHAT_IDS=1234567890

# A2A — peers with the other two runtimes in this fleet
PB_A2A_BEARER_TOKEN=a2a_bearer_token_456
PB_A2A_SELF_BASE_URL=http://assistant:8000
PB_A2A_PEERS_JSON=[{"runtime_id":"generalist","base_url":"http://generalist:8000"},{"runtime_id":"cron-worker","base_url":"http://cron-worker:8000"}]
PB_A2A_AGENT_DESCRIPTION='Assistant — short personal exchanges, reminders, image recognition.'
