# Cron-worker — local model via genai-proxy. Bundled memory + HTTP trigger
# ingress for external event sources. Ideal for scheduled, low-cost background
# jobs.

# Runtime identity
PB_RUNTIME_ID=cron-worker
PB_AGENT_NAME=CronWorker

# Container-local runtime state
PB_BASE_DIR=/home/pillbug

# Gemini wire-format, but pointed at the genai-proxy sidecar that translates
# to an OpenAI-compatible upstream (llama.cpp / vLLM / Ollama / LiteLLM).
# The model id you set here must be one the upstream actually serves.
PB_GEMINI_API_KEY=unused_but_required
PB_GEMINI_BASE_URL=http://genai-proxy:9031
PB_GEMINI_MODEL=local-gemma
PB_GEMINI_THINKING_LEVEL=low

# Redis (bundled service in this compose stack) — used by the embedded Docket
# scheduler for cron-shaped tasks.
PB_REDIS_HOST=redis
PB_REDIS_PORT=6379
PB_REDIS_DB=5
PB_DOCKET_NAME=d_cron_worker

# Summarization
PB_SESSION_SUMMARIZATION="compress"
PB_SESSION_SUMMARIZATION_THRESHOLD=32768

# HTTP server
PB_MCP_HOST=0.0.0.0
PB_MCP_PORT=8000

PB_DASHBOARD_BEARER_TOKEN=dashboard_bearer_token_123

# HTTP trigger ingress (external systems POST events here)
PB_TRIGGER_HOST=0.0.0.0
PB_TRIGGER_PORT=9100
PB_TRIGGER_BEARER_TOKEN=trigger_bearer_token_321

# Channels — A2A keeps the runtime serving; trigger exposes the HTTP ingress.
# (Bundled `memory` is enabled via the install extra, not the channel list:
# it registers MCP tools, not a channel.)
PB_ENABLED_CHANNELS=a2a,trigger
PB_CHANNEL_PLUGIN_FACTORIES=a2a=pillbug_a2a.a2a_channel:create_channel,trigger=pillbug_trigger:create_channel

# A2A — peers with the other two runtimes in this fleet
PB_A2A_BEARER_TOKEN=a2a_bearer_token_456
PB_A2A_SELF_BASE_URL=http://cron-worker:8000
PB_A2A_PEERS_JSON=[{"runtime_id":"generalist","base_url":"http://generalist:8000"},{"runtime_id":"assistant","base_url":"http://assistant:8000"}]
PB_A2A_AGENT_DESCRIPTION='Cron-worker — local model, scheduled tasks, trigger handler.'
