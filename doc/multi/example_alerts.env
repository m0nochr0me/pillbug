# Google API key for Public Alerts
GOOGLE_API_KEY=google_weather_api_key

# Pillbug trigger endpoint (e.g. http://pillbug-a:9100/trigger inside compose)
TRIGGER_HOST=http://pillbug-a:9100/trigger

# Bearer token matching PB_TRIGGER_BEARER_TOKEN on the target runtime
PB_TRIGGER_BEARER_TOKEN=trigger_bearer_token_321

# Target location (defaults to Cebu City)
ALERT_LATITUDE=10.3100072
ALERT_LONGITUDE=123.8955921
