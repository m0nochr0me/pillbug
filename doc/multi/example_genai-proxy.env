# Gemini → OpenAI-compatible translation proxy. Lets cron-worker speak the
# Gemini wire format while a local backend (llama.cpp / vLLM / Ollama /
# LiteLLM) serves the model.

PB_GENAI_PROXY_HOST=0.0.0.0
PB_GENAI_PROXY_PORT=9031

# Upstream OpenAI-compatible /v1 endpoint. The default below points at a
# host-local server (e.g. llama-server / ollama) reachable from inside the
# container via host.docker.internal.
PB_GENAI_PROXY_UPSTREAM_URL=http://host.docker.internal:8080/v1

# Optional — only needed if your upstream requires it.
# PB_GENAI_PROXY_UPSTREAM_API_KEY=upstream_api_key

# Optional — pin a model id the upstream actually serves. When unset, the
# requested model from the runtime is forwarded as-is.
# PB_GENAI_PROXY_UPSTREAM_MODEL=local-gemma

PB_GENAI_PROXY_REQUEST_TIMEOUT_SECONDS=600
PB_GENAI_PROXY_UPSTREAM_VERIFY_TLS=true
