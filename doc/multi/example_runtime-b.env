# Runtime identity
PB_RUNTIME_ID=trinity
PB_AGENT_NAME=Trinity

# Container-local runtime state
PB_BASE_DIR=/home/pillbug

# Gemini
PB_GEMINI_API_KEY=your_gemini_token
PB_GEMINI_MODEL=gemini-3.1-flash-lite-preview
PB_GEMINI_THINKING_LEVEL=medium

# Redis
PB_REDIS_HOST=host.docker.internal
PB_REDIS_PORT=6379
PB_REDIS_DB=5

PB_DOCKET_NAME=d_trinity

# Summarization
PB_SESSION_SUMMARIZATION="compress"
PB_SESSION_SUMMARIZATION_THRESHOLD=32768

# HTTP server
PB_MCP_HOST=0.0.0.0
PB_MCP_PORT=8000

PB_DASHBOARD_BEARER_TOKEN=dashboard_bearer_token_123

# Enable the A2A channel so the container keeps serving after startup
PB_ENABLED_CHANNELS=a2a
PB_CHANNEL_PLUGIN_FACTORIES=a2a=pillbug_a2a.a2a_channel:create_channel



# A2A settings
PB_A2A_BEARER_TOKEN=a2a_bearer_token_456
PB_A2A_SELF_BASE_URL=http://pillbug-b:8000
PB_A2A_PEERS_JSON=[{"runtime_id":"smith","base_url":"http://pillbug-a:8000"}]
PB_A2A_AGENT_DESCRIPTION='Trinity - pew pew pew'
