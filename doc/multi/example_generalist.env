# Generalist — Gemini Pro on Matrix, peers with cron-worker and assistant.

# Runtime identity
PB_RUNTIME_ID=generalist
PB_AGENT_NAME=Generalist

# Container-local runtime state
PB_BASE_DIR=/home/pillbug

# Gemini (Pro, full thinking budget)
PB_GEMINI_API_KEY=your_gemini_token
PB_GEMINI_MODEL=gemini-3.1-pro-preview
PB_GEMINI_THINKING_LEVEL=high
PB_GEMINI_TOP_P=0.7
PB_GEMINI_MAX_OUTPUT_TOKENS=65534
PB_GEMINI_EMPTY_RESPONSE_MAX_NUDGES=6

# Redis (bundled service in this compose stack)
PB_REDIS_HOST=redis
PB_REDIS_PORT=6379
PB_REDIS_DB=5
PB_DOCKET_NAME=d_generalist

# Summarization
PB_SESSION_SUMMARIZATION="compress"
PB_SESSION_SUMMARIZATION_THRESHOLD=262144

# HTTP server
PB_MCP_HOST=0.0.0.0
PB_MCP_PORT=8000

PB_DASHBOARD_BEARER_TOKEN=dashboard_bearer_token_123

# Channels
PB_ENABLED_CHANNELS=a2a,matrix
PB_CHANNEL_PLUGIN_FACTORIES=a2a=pillbug_a2a.a2a_channel:create_channel,matrix=pillbug_matrix.matrix_channel:create_channel

# Matrix
PB_MATRIX_HOMESERVER=https://matrix.example.org
PB_MATRIX_USER_ID=@generalist:example.org
PB_MATRIX_ACCESS_TOKEN=matrix_access_token
PB_MATRIX_ALLOWED_ROOM_IDS=!yourRoomId:example.org

# A2A — peers with the other two runtimes in this fleet
PB_A2A_BEARER_TOKEN=a2a_bearer_token_456
PB_A2A_SELF_BASE_URL=http://generalist:8000
PB_A2A_PEERS_JSON=[{"runtime_id":"cron-worker","base_url":"http://cron-worker:8000"},{"runtime_id":"assistant","base_url":"http://assistant:8000"}]
PB_A2A_AGENT_DESCRIPTION='Generalist agent — long-form work, web research, social posting.'

# Skill helper settings (text-to-speech, tavily-search).
# API keys are NOT set here: skill scripts run in the execute_command sandbox,
# which strips secret-named variables. Provide them as files instead --
# /run/secrets/elevenlabs_api_key and /run/secrets/tavily_api_key (see
# doc/INSTALL.md -> Skill Secrets). The non-secret settings below reach skill
# subprocesses only via PB_EXECUTE_COMMAND_ENV_PASSTHROUGH:
PB_EXECUTE_COMMAND_ENV_PASSTHROUGH=ELEVENLABS_VOICE_ID,ELEVENLABS_MODEL,ELEVENLABS_STABILITY,ELEVENLABS_SIMILARITY,ELEVENLABS_SPEED,ELEVENLABS_OUTPUT,TAVILY_DEPTH,TAVILY_TOP_K

# Elevenlabs (text-to-speech)
ELEVENLABS_VOICE_ID=some_voice_id
ELEVENLABS_MODEL=eleven_v3
ELEVENLABS_STABILITY=1.0
ELEVENLABS_SIMILARITY=1.0
ELEVENLABS_SPEED=1.0
ELEVENLABS_OUTPUT=opus_48000_192

# Tavily (tavily-search)
TAVILY_DEPTH=ultra-fast
TAVILY_TOP_K=10
