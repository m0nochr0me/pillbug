# Runtime identity
PB_RUNTIME_ID=smith
PB_AGENT_NAME=AgentSmith

# Container-local runtime state
PB_BASE_DIR=/home/pillbug

# Gemini
PB_GEMINI_API_KEY=your_gemini_token
PB_GEMINI_MODEL=gemini-3.1-pro-preview
PB_GEMINI_THINKING_LEVEL=high
PB_GEMINI_TOP_P=0.7
PB_GEMINI_MAX_OUTPUT_TOKENS=65534
PB_GEMINI_EMPTY_RESPONSE_MAX_NUDGES=6

# Redis
PB_REDIS_HOST=host.docker.internal
PB_REDIS_PORT=6379
PB_REDIS_DB=5

PB_DOCKET_NAME=d_smith

# Summarization
PB_SESSION_SUMMARIZATION="compress"
PB_SESSION_SUMMARIZATION_THRESHOLD=262144

# HTTP server
PB_MCP_HOST=0.0.0.0
PB_MCP_PORT=8000

PB_DASHBOARD_BEARER_TOKEN=dashboard_bearer_token_123

# Triggers
PB_TRIGGER_HOST=0.0.0.0
PB_TRIGGER_PORT=9100
PB_TRIGGER_BEARER_TOKEN=trigger_bearer_token_321

# Channels
PB_ENABLED_CHANNELS=cli,telegram,trigger
PB_CHANNEL_PLUGIN_FACTORIES=telegram=pillbug_telegram.telegram_channel:create_channel,trigger=pillbug_trigger:create_channel

# Telegram
PB_TELEGRAM_BOT_TOKEN=111222333:tg_bot_token
PB_TELEGRAM_ALLOWED_CHAT_IDS=1234567890

# Elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=some_voice_id
ELEVENLABS_MODEL=eleven_v3
ELEVENLABS_STABILITY=1.0
ELEVENLABS_SIMILARITY=1.0
ELEVENLABS_SPEED=1.0
ELEVENLABS_OUTPUT=opus_48000_192

# Tavily
TAVILY_API_KEY=your_tavily_key
TAVILY_DEPTH=ultra-fast
TAVILY_TOP_K=10
